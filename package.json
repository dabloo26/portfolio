{
  "name": "portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node -e \"require('fs').copyFileSync('dist/index.html','dist/404.html')\"",
    "preview": "vite preview",
    "lint": "eslint .",
    "h1b:scrape-good-sponsors": "node h1b-companyscraper/scrapeH1BSponsors.mjs",
    "h1b:build-pipeline-sheet": "node h1b-companyscraper/buildH1BPipelineSheet.mjs",
    "leads:generate": "node scripts/leadgen/generateLeads.mjs",
    "outreach:combine": "node scripts/outreach/combineTechnicalRecruiters.mjs",
    "outreach:targets": "node scripts/outreach/applyJobTargets.mjs",
    "outreach:import-manual": "node scripts/outreach/importManualRecruiters.mjs",
    "outreach:preview": "node scripts/outreach/previewOutreach.mjs",
    "outreach:send": "node scripts/outreach/sendOutreach.mjs",
    "wealthsense:train": "DYLD_LIBRARY_PATH=/opt/homebrew/opt/expat/lib:$DYLD_LIBRARY_PATH PYTHONPATH=wealthsense-ai/src python3 -m wealthsense_ai.train",
    "wealthsense:dashboard": "DYLD_LIBRARY_PATH=/opt/homebrew/opt/expat/lib:$DYLD_LIBRARY_PATH PYTHONPATH=wealthsense-ai/src python3 -m streamlit run wealthsense-ai/src/wealthsense_ai/app.py"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "framer-motion": "^11.11.17",
    "nodemailer": "^6.9.16",
    "playwright": "^1.59.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^16.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "vite": "^5.4.11"
